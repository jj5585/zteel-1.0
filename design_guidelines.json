      "sushi_platter": "https://images.unsplash.com/photo-1706267701242-c518dce7f113?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjAzMzl8MHwxfHNlYXJjaHwyfHxzdXNoaSUyMHBsYXR0ZXIlMjB2aWJyYW50JTIwY29sb3JzJTIwdG9wJTIwdmlld3xlbnwwfHx8fDE3NzM0NDgwMzl8MA&ixlib=rb-4.1.0&q=85",
      "street_market": "https://images.unsplash.com/photo-1760262492874-80283261b99c?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjA1NTN8MHwxfHNlYXJjaHwxfHxidXN5JTIwaW5kaWFuJTIwc3RyZWV0JTIwZm9vZCUyMG1hcmtldCUyMG5pZ2h0fGVufDB8fHx8MTc3MzQ0ODA0MHww&ixlib=rb-4.1.0&q=85",
      "map_marker_default": "https://cdn-icons-png.flaticon.com/512/684/684908.png",
      "map_marker_active": "https://cdn-icons-png.flaticon.com/512/684/684908.png"
    },
    "icons": {
      "library": "lucide-react-native",
      "style": "strokeWidth={2} color={currentColor}"
    }
  },
  "instructions_to_main_agent": [
    "Do not use HTML tags (div, span, h1). Use React Native components: View, Text, TouchableOpacity, ScrollView, FlatList.",
    "Use StyleSheet.create for styling. Do not use inline styles unless for dynamic values.",
    "For shadows on Android, use 'elevation'. For iOS, use shadowColor/Offset/Opacity/Radius.",
    "Use 'SafeAreaView' from 'react-native-safe-area-context' for screen wrappers.",
    "Implement 'Expo Image' for better caching and performance instead of standard Image component.",
    "For gradients, use 'expo-linear-gradient'.",
    "Respect the 'Customer' vs 'Vendor' theme separation. Toggle theme based on user role context, not just system theme.",
    "Ensure all touch targets are at least 44x44 points.",
    "Use the provided image URLs for placeholders. Do not leave empty boxes.",
    "For maps, use 'react-native-maps' with the custom dark JSON style for Vendor and Standard style for Customer.",
    "Add 'data-testid' to all interactables."
  ]
}