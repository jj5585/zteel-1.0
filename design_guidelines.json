    },
    "vendor": {
      "name": "Command Center",
      "keywords": ["Precise", "Calm", "Data-Rich", "Professional"],
      "mode": "Dark",
      "visual_anchor": "Swiss Utility"
    }
  },
  "colors": {
    "customer": {
      "primary": "#FF5722",
      "primary_foreground": "#FFFFFF",
      "secondary": "#CCFF00",
      "secondary_foreground": "#000000",
      "background": "#F8F9FA",
      "surface": "#FFFFFF",
      "text_primary": "#121212",
      "text_secondary": "#64748B",
      "border": "#E2E8F0",
      "success": "#10B981",
      "error": "#EF4444",
      "warning": "#F59E0B"
    },
    "vendor": {
      "primary": "#3B82F6",
      "primary_foreground": "#FFFFFF",
      "secondary": "#10B981",
      "secondary_foreground": "#FFFFFF",
      "background": "#0F172A",
      "surface": "#1E293B",
      "text_primary": "#F8FAFC",
      "text_secondary": "#94A3B8",
      "border": "#334155",
      "chart_1": "#3B82F6",
      "chart_2": "#10B981",
      "chart_3": "#F59E0B",
      "chart_4": "#8B5CF6",
      "chart_5": "#EC4899"
    },
    "shared": {
      "transparent": "transparent",
      "white": "#FFFFFF",
      "black": "#000000",
      "overlay": "rgba(0,0,0,0.5)"
    }
  },
  "typography": {
    "font_family": {
      "heading": "SpaceGrotesk",
      "body": "Manrope",
      "fallback": "System"
    },
    "scale": {
      "h1": { "size": 32, "lineHeight": 40, "weight": "700", "letterSpacing": -1 },
      "h2": { "size": 24, "lineHeight": 32, "weight": "600", "letterSpacing": -0.5 },
      "h3": { "size": 20, "lineHeight": 28, "weight": "600" },
      "body_lg": { "size": 18, "lineHeight": 28, "weight": "400" },
      "body": { "size": 16, "lineHeight": 24, "weight": "400" },
      "caption": { "size": 14, "lineHeight": 20, "weight": "500", "color": "#64748B" },
      "tiny": { "size": 12, "lineHeight": 16, "weight": "600", "textTransform": "uppercase", "letterSpacing": 1 }
    }
  },
  "spacing": {
    "scale": {
      "xs": 4,
      "s": 8,
      "m": 16,
      "l": 24,
      "xl": 32,
      "xxl": 48
    },
    "layout": {
      "screen_padding": 20,
      "card_padding": 16,
      "gap_small": 8,
      "gap_medium": 16,
      "gap_large": 24
    }
  },
  "border_radius": {
    "small": 8,
    "medium": 12,
    "large": 16,
    "pill": 9999
  },
  "shadows": {
    "soft": {
      "shadowColor": "#000",
      "shadowOffset": { "width": 0, "height": 4 },
      "shadowOpacity": 0.06,
      "shadowRadius": 8,
      "elevation": 2
    },
    "medium": {
      "shadowColor": "#000",
      "shadowOffset": { "width": 0, "height": 8 },
      "shadowOpacity": 0.12,
      "shadowRadius": 16,
      "elevation": 4
    },
    "hard": {
      "shadowColor": "#000",
      "shadowOffset": { "width": 4, "height": 4 },
      "shadowOpacity": 1,
      "shadowRadius": 0,
      "elevation": 0
    }
  },
  "layout_strategies": {
    "customer_home": {
      "type": "masonry_vertical",
      "description": "A dense, high-energy feed of deals. Mix large 'Hero Deals' (full width) with smaller 'Quick Grabs' (half width)."
    },
    "vendor_dashboard": {
      "type": "bento_grid",
      "description": "Grid of analytic widgets. Dark mode cards with single bright data points."
    }
  },
  "components": {
    "Button": {
      "variants": {
        "primary": {
          "backgroundColor": "primary",
          "borderRadius": "pill",
          "paddingVertical": 16,
          "paddingHorizontal": 24,
          "elevation": 0
        },
        "secondary": {
          "backgroundColor": "secondary",
          "borderRadius": "pill",
          "paddingVertical": 16,
          "paddingHorizontal": 24,
          "borderWidth": 1,
          "borderColor": "black"
        },
        "ghost": {
          "backgroundColor": "transparent",
          "paddingVertical": 12
        }
      }
    },
    "Card": {
      "customer": {
        "backgroundColor": "white",
        "borderRadius": 16,
        "borderWidth": 1,
        "borderColor": "#E2E8F0",
        "overflow": "hidden"
      },
      "vendor": {
        "backgroundColor": "#1E293B",
        "borderRadius": 12,
        "borderWidth": 1,
        "borderColor": "#334155"
      }
    },
    "Input": {
      "height": 56,
      "borderRadius": 12,
      "backgroundColor": "#F1F5F9",
      "paddingHorizontal": 16,
      "fontSize": 16,
      "borderWidth": 1,
      "borderColor": "transparent",
      "focusBorderColor": "primary"
    }
  },
  "visual_enhancers": {
    "glassmorphism": {
      "backgroundColor": "rgba(255, 255, 255, 0.8)",
      "blurIntensity": 20,
      "borderColor": "rgba(255, 255, 255, 0.3)",
      "borderWidth": 1
    },
    "gradients": {
      "clearance_deal": ["#FF5722", "#FF8A65"],
      "slow_hour": ["#10B981", "#34D399"]
    }
  },
  "assets": {
    "images": {
